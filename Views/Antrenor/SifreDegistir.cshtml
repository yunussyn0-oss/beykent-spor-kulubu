@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <title>Şifre Değiştir - Beylikdüzü Beykent Spor Kulübü</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: linear-gradient(135deg, #0B2A4A 0%, #1B3B5C 50%, #2C4A6E 100%);
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .card-custom {
            background: white;
            border-radius: 32px;
            padding: 40px;
            max-width: 520px;
            width: 100%;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25);
            animation: slideUp 0.5s ease-out;
        }
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .logo-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #0B2A4A, #1B3B5C);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }
        .logo-icon i { font-size: 35px; color: #FFD700; }
        h2 { color: #0B2A4A; font-size: 24px; font-weight: 700; text-align: center; margin-bottom: 8px; }
        .subtitle { text-align: center; color: #6B7A8F; font-size: 14px; margin-bottom: 30px; }
        .form-group { margin-bottom: 25px; }
        .form-group label { font-weight: 600; font-size: 13px; text-transform: uppercase; color: #0B2A4A; margin-bottom: 8px; display: block; }
        .input-wrapper { position: relative; }
        .input-icon { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #0B2A4A; font-size: 18px; z-index: 10; }
        .form-control {
            width: 100%;
            padding: 15px 20px 15px 50px;
            font-size: 15px;
            border: 2px solid #e1e5e9;
            border-radius: 16px;
            transition: all 0.3s;
        }
        .form-control:focus { border-color: #0B2A4A; box-shadow: 0 0 0 4px rgba(11,42,74,0.1); outline: none; }
        .password-toggle {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #6B7A8F;
            cursor: pointer;
        }
        .password-toggle:hover { color: #0B2A4A; }
        .btn-primary {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #0B2A4A, #1B3B5C);
            border: none;
            border-radius: 16px;
            color: white;
            font-size: 16px;
            font-weight: 600;
            transition: all 0.3s;
            cursor: pointer;
        }
        .btn-primary:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(11,42,74,0.4); }
        .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
        .btn-secondary {
            width: 100%;
            padding: 14px;
            background: #6c757d;
            border: none;
            border-radius: 16px;
            color: white;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            text-align: center;
            display: inline-block;
            margin-top: 12px;
        }
        .btn-secondary:hover { background: #5a6268; transform: translateY(-2px); }
        .alert-custom { border-radius: 16px; padding: 12px 18px; margin-bottom: 20px; display: flex; align-items: center; gap: 12px; }
        .alert-danger-custom { background: linear-gradient(135deg, #fee, #ffd1d1); color: #a00; border-left: 4px solid #dc3545; }
        .alert-success-custom { background: linear-gradient(135deg, #e8f5e8, #d4edda); color: #155724; border-left: 4px solid #28a745; }
        .strength-bar { height: 6px; border-radius: 3px; transition: all 0.3s; margin-top: 10px; background: #e1e5e9; }
        .strength-bar.weak { width: 25%; background: #dc3545; }
        .strength-bar.medium { width: 50%; background: #ffc107; }
        .strength-bar.strong { width: 75%; background: #28a745; }
        .strength-bar.very-strong { width: 100%; background: #0B2A4A; }
        .strength-text { font-size: 12px; margin-top: 6px; }
        .requirement { font-size: 12px; margin-top: 6px; display: flex; align-items: center; gap: 8px; }
        .requirement i { font-size: 12px; }
        .requirement.valid { color: #28a745; }
        .requirement.invalid { color: #6B7A8F; }
        .footer-links { text-align: center; margin-top: 25px; display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; }
        .footer-links a { color: #6B7A8F; text-decoration: none; font-size: 13px; transition: color 0.2s; }
        .footer-links a:hover { color: #0B2A4A; }
        @@media (max-width: 576px) {
            .card-custom { padding: 30px 25px; }
            h2 { font-size: 20px; }
        }
    </style>
</head>
<body>
    <div class="card-custom">
        <div class="logo-icon">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h2>Şifre Değiştir</h2>
        <p class="subtitle">Hesap güvenliğiniz için şifrenizi düzenli olarak değiştirin</p>

        @if (ViewBag.Hata != null)
        {
            <div class="alert-custom alert-danger-custom">
                <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                <div>@ViewBag.Hata</div>
            </div>
        }

        @if (TempData["Basarili"] != null)
        {
            <div class="alert-custom alert-success-custom">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <div>@TempData["Basarili"]</div>
            </div>
        }

        <form method="post" action="/Antrenor/SifreDegistir" id="sifreForm">
            <!-- Eski Şifre -->
            <div class="form-group">
                <label><i class="bi bi-lock-fill me-1"></i> Mevcut Şifre</label>
                <div class="input-wrapper">
                    <i class="bi bi-shield-lock input-icon"></i>
                    <input type="password" name="eskiSifre" id="eskiSifre" class="form-control" placeholder="••••••••" required>
                    <button type="button" class="password-toggle" onclick="togglePassword('eskiSifre', 'toggleEski')">
                        <i class="bi bi-eye" id="toggleEski"></i>
                    </button>
                </div>
            </div>

            <!-- Yeni Şifre -->
            <div class="form-group">
                <label><i class="bi bi-key-fill me-1"></i> Yeni Şifre</label>
                <div class="input-wrapper">
                    <i class="bi bi-key input-icon"></i>
                    <input type="password" name="yeniSifre" id="yeniSifre" class="form-control" placeholder="••••••••" required>
                    <button type="button" class="password-toggle" onclick="togglePassword('yeniSifre', 'toggleYeni')">
                        <i class="bi bi-eye" id="toggleYeni"></i>
                    </button>
                </div>
                <div class="strength-bar" id="strengthBar"></div>
                <div class="strength-text" id="strengthText"></div>
                <div class="requirement invalid" id="reqLength">
                    <i class="bi bi-circle" id="reqLengthIcon"></i>
                    <span>En az 6 karakter</span>
                </div>
                <div class="requirement invalid" id="reqLower">
                    <i class="bi bi-circle" id="reqLowerIcon"></i>
                    <span>En az 1 küçük harf (a-z)</span>
                </div>
                <div class="requirement invalid" id="reqUpper">
                    <i class="bi bi-circle" id="reqUpperIcon"></i>
                    <span>En az 1 büyük harf (A-Z)</span>
                </div>
                <div class="requirement invalid" id="reqNumber">
                    <i class="bi bi-circle" id="reqNumberIcon"></i>
                    <span>En az 1 sayı (0-9)</span>
                </div>
            </div>

            <!-- Yeni Şifre Tekrar -->
            <div class="form-group">
                <label><i class="bi bi-key-fill me-1"></i> Yeni Şifre (Tekrar)</label>
                <div class="input-wrapper">
                    <i class="bi bi-key input-icon"></i>
                    <input type="password" name="yeniSifreTekrar" id="yeniSifreTekrar" class="form-control" placeholder="••••••••" required>
                    <button type="button" class="password-toggle" onclick="togglePassword('yeniSifreTekrar', 'toggleTekrar')">
                        <i class="bi bi-eye" id="toggleTekrar"></i>
                    </button>
                </div>
                <div class="requirement invalid" id="reqMatch">
                    <i class="bi bi-circle" id="reqMatchIcon"></i>
                    <span>Şifreler eşleşiyor</span>
                </div>
            </div>

            <button type="submit" class="btn-primary" id="submitBtn">
                <i class="bi bi-save me-2"></i>Şifreyi Güncelle
            </button>
            <a href="/Antrenor/Panel" class="btn-secondary">
                <i class="bi bi-arrow-left me-2"></i>İptal
            </a>
        </form>

        <div class="footer-links">
            <a href="/Antrenor/SifremiUnuttum">
                <i class="bi bi-question-circle me-1"></i>Şifremi Unuttum
            </a>
            <a href="/Antrenor/Giris">
                <i class="bi bi-box-arrow-right me-1"></i>Giriş Sayfası
            </a>
        </div>
    </div>

    <script>
        function togglePassword(inputId, toggleId) {
            var input = document.getElementById(inputId);
            var icon = document.getElementById(toggleId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }

        function checkPasswordStrength(password) {
            let strength = 0;
            if (password.length >= 6) strength++;
            if (/[a-z]/.test(password)) strength++;
            if (/[A-Z]/.test(password)) strength++;
            if (/[0-9]/.test(password)) strength++;
            return strength;
        }

        function updateStrengthIndicator(password) {
            const strength = checkPasswordStrength(password);
            const bar = document.getElementById('strengthBar');
            const text = document.getElementById('strengthText');
            
            bar.className = 'strength-bar';
            if (password.length === 0) {
                bar.style.width = '0%';
                text.innerHTML = '';
            } else if (strength <= 1) {
                bar.style.width = '25%';
                bar.classList.add('weak');
                text.innerHTML = '🔒 Zayıf şifre - daha güçlü bir şifre oluşturun';
                text.style.color = '#dc3545';
            } else if (strength === 2) {
                bar.style.width = '50%';
                bar.classList.add('medium');
                text.innerHTML = '⚠️ Orta şifre - daha güçlü olabilir';
                text.style.color = '#ffc107';
            } else if (strength === 3) {
                bar.style.width = '75%';
                bar.classList.add('strong');
                text.innerHTML = '✅ Güçlü şifre';
                text.style.color = '#28a745';
            } else {
                bar.style.width = '100%';
                bar.classList.add('very-strong');
                text.innerHTML = '💪 Çok güçlü şifre';
                text.style.color = '#0B2A4A';
            }
        }

        function updateRequirement(elementId, iconId, isValid) {
            const element = document.getElementById(elementId);
            const icon = document.getElementById(iconId);
            if (isValid) {
                element.classList.remove('invalid');
                element.classList.add('valid');
                icon.classList.remove('bi-circle');
                icon.classList.add('bi-check-circle-fill');
            } else {
                element.classList.remove('valid');
                element.classList.add('invalid');
                icon.classList.remove('bi-check-circle-fill');
                icon.classList.add('bi-circle');
            }
        }

        function validateForm() {
            const yeniSifre = document.getElementById('yeniSifre').value;
            const yeniSifreTekrar = document.getElementById('yeniSifreTekrar').value;
            
            const lengthValid = yeniSifre.length >= 6;
            const lowerValid = /[a-z]/.test(yeniSifre);
            const upperValid = /[A-Z]/.test(yeniSifre);
            const numberValid = /[0-9]/.test(yeniSifre);
            const matchValid = (yeniSifre === yeniSifreTekrar) && yeniSifre !== '';
            
            updateRequirement('reqLength', 'reqLengthIcon', lengthValid);
            updateRequirement('reqLower', 'reqLowerIcon', lowerValid);
            updateRequirement('reqUpper', 'reqUpperIcon', upperValid);
            updateRequirement('reqNumber', 'reqNumberIcon', numberValid);
            updateRequirement('reqMatch', 'reqMatchIcon', matchValid);
            
            updateStrengthIndicator(yeniSifre);
            
            const allValid = lengthValid && lowerValid && upperValid && numberValid && matchValid;
            const submitBtn = document.getElementById('submitBtn');
            if (submitBtn) submitBtn.disabled = !allValid;
            return allValid;
        }

        const yeniSifreInput = document.getElementById('yeniSifre');
        const yeniSifreTekrarInput = document.getElementById('yeniSifreTekrar');
        
        if (yeniSifreInput) yeniSifreInput.addEventListener('input', validateForm);
        if (yeniSifreTekrarInput) yeniSifreTekrarInput.addEventListener('input', validateForm);
        
        const sifreForm = document.getElementById('sifreForm');
        if (sifreForm) {
            sifreForm.addEventListener('submit', function(e) {
                if (!validateForm()) {
                    e.preventDefault();
                    alert('Lütfen tüm şifre kurallarını sağlayın!');
                }
            });
        }
        
        validateForm();
    </script>
</body>
</html>
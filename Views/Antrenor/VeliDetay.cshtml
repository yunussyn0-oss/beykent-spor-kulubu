@model SporKulubu.Models.Uye
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Veli İletişim - @Model.AdSoyad</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; }
        .navbar-custom { background: linear-gradient(135deg, #0B2A4A 0%, #1B3B5C 100%); padding: 12px 0; }
        .navbar-custom .navbar-brand, .navbar-custom .nav-link { color: white !important; }
        .card-custom { background: white; border-radius: 20px; box-shadow: 0 5px 20px rgba(0,0,0,0.08); border: none; }
        .btn-wa { background: #25D366; color: white; border: none; }
        .btn-wa:hover { background: #128C7E; color: white; }
        .profile-img { width: 150px; height: 150px; border-radius: 50%; object-fit: cover; border: 4px solid #0B2A4A; }
        @@media (max-width: 768px) {
            .profile-img { width: 100px; height: 100px; }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand fw-bold" href="@Url.Action("Panel", "Antrenor")">
                <i class="bi bi-trophy-fill me-2"></i>BEYLİKDÜZÜ BEYKENT SPOR
            </a>
            <a class="nav-link" href="@Url.Action("Panel", "Antrenor")"><i class="bi bi-arrow-left me-1"></i>Panele Dön</a>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row">
            <div class="col-md-4">
                <div class="card-custom p-4 text-center">
                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model.SporcuFoto))
                        {
                            <img src="@Model.SporcuFoto" class="profile-img" id="sporcuResim">
                        }
                        else
                        {
                            <img src="https://placehold.co/150x150/0B2A4A/white?text=@Model.AdSoyad.Substring(0,1)" class="profile-img" id="sporcuResim">
                        }
                        
                        <form method="post" action="@Url.Action("SporcuFotoYukle", "Antrenor")" enctype="multipart/form-data" class="mt-2" id="fotoForm">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <label class="btn btn-sm btn-outline-primary mt-2">
                                <i class="bi bi-camera me-1"></i>Fotoğraf Yükle
                                <input type="file" name="file" accept="image/*" style="display:none" onchange="this.form.submit()" />
                            </label>
                        </form>
                    </div>
                    
                    <h4 class="fw-bold">@Model.AdSoyad</h4>
                    <p class="text-muted">@(Model.Brans?.Ad ?? "-") / @(Model.Takim?.Ad ?? "-")</p>
                    <hr />
                    <div class="text-start">
                        <p><i class="bi bi-calendar me-2"></i> Doğum: @Model.DogumTarihi.ToShortDateString()</p>
                        <p><i class="bi bi-building me-2"></i> Salon: @(Model.SporSalonu?.Ad ?? "-")</p>
                        <p><i class="bi bi-diagram-3 me-2"></i> Grup: @(Model.Grup?.Ad ?? "-")</p>
                        <p><i class="bi bi-currency-dollar me-2"></i> Aidat: ₺@Model.AylikAidat.ToString("N0")</p>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card-custom p-4 mb-4">
                    <h5><i class="bi bi-people me-2"></i>Veli Bilgileri</h5>
                    <hr />
                    <div class="row">
                        <div class="col-md-6">
                            <p><i class="bi bi-person me-2"></i> <strong>Veli Adı:</strong> @Model.VeliAdSoyad</p>
                        </div>
                        <div class="col-md-6">
                            <p><i class="bi bi-telephone me-2"></i> <strong>Telefon:</strong> @Model.VeliTelefon</p>
                        </div>
                    </div>
                </div>

                <div class="card-custom p-4">
                    <h5><i class="bi bi-chat-dots me-2"></i>Hızlı İletişim</h5>
                    <hr />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <a href="https://wa.me/@Model.VeliTelefon?.Replace(" ", "")" target="_blank" class="btn btn-wa w-100 py-3">
                                <i class="bi bi-whatsapp me-2 fs-5"></i> WhatsApp'tan Mesaj Gönder
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a href="tel:@Model.VeliTelefon" class="btn btn-primary w-100 py-3">
                                <i class="bi bi-telephone-fill me-2 fs-5"></i> Telefonla Ara
                            </a>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-outline-secondary w-100 py-3" id="copyPhone">
                                <i class="bi bi-files me-2 fs-5"></i> Telefonu Kopyala
                            </button>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <a href="@Url.Action("Panel", "Antrenor")" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-left me-2"></i>Panele Dön
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('copyPhone')?.addEventListener('click', function() {
            navigator.clipboard.writeText('@Model.VeliTelefon').then(() => {
                alert('Telefon numarası kopyalandı: @Model.VeliTelefon');
            });
        });
    </script>
</body>
</html>
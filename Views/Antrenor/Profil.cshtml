@model SporKulubu.Models.Antrenor
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profilim - Beylikdüzü Beykent Spor</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; }
        .navbar-custom { background: linear-gradient(135deg, #0B2A4A 0%, #1B3B5C 100%); padding: 12px 0; }
        .navbar-custom .navbar-brand, .navbar-custom .nav-link { color: white !important; }
        .profile-card { background: white; border-radius: 24px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        .profile-header { background: linear-gradient(135deg, #0B2A4A 0%, #1B3B5C 100%); height: 120px; }
        .profile-avatar { margin-top: -60px; text-align: center; }
        .profile-avatar img { width: 120px; height: 120px; border-radius: 50%; border: 4px solid white; object-fit: cover; background: white; }
        .avatar-upload { position: relative; margin-top: 10px; }
        .avatar-upload .btn-upload { background: #0B2A4A; color: white; border-radius: 50%; width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; border: 2px solid white; }
        .file-input { display: none; }
        .btn-custom { background: linear-gradient(135deg, #0B2A4A, #1B3B5C); color: white; border: none; padding: 10px 25px; border-radius: 10px; transition: all 0.3s; }
        .btn-custom:hover { transform: translateY(-2px); color: white; }
        .alert-custom { border-radius: 12px; padding: 12px 18px; margin-bottom: 20px; }
        .alert-success-custom { background: #d4edda; color: #155724; border-left: 4px solid #28a745; }
        .alert-danger-custom { background: #f8d7da; color: #721c24; border-left: 4px solid #dc3545; }
        @@media (max-width: 768px) {
            .profile-card { margin: 0 10px; }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand fw-bold" href="@Url.Action("Panel", "Antrenor")">
                <i class="bi bi-trophy-fill me-2"></i>BEYLİKDÜZÜ BEYKENT SPOR
            </a>
            <div class="ms-auto">
                <a class="nav-link d-inline-block" href="@Url.Action("Panel", "Antrenor")">
                    <i class="bi bi-arrow-left me-1"></i>Panele Dön
                </a>
                <a class="nav-link d-inline-block ms-3" href="@Url.Action("Cikis", "Antrenor")">
                    <i class="bi bi-box-arrow-right me-1"></i>Çıkış
                </a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="profile-card">
                    <div class="profile-header"></div>
                    
                    <div class="text-center profile-avatar">
                        @if (!string.IsNullOrEmpty(Model.ProfilResmi))
                        {
                            <img src="@Model.ProfilResmi" alt="Profil Resmi" id="profilResim">
                        }
                        else
                        {
                            <img src="https://placehold.co/120x120/0B2A4A/white?text=@Model.AdSoyad.Substring(0,1)" alt="Profil Resmi" id="profilResim">
                        }
                        <div class="avatar-upload">
                            <form method="post" action="@Url.Action("ProfilResmiYukle", "Antrenor")" enctype="multipart/form-data" id="fotoForm">
                                <label class="btn-upload" id="uploadLabel">
                                    <i class="bi bi-camera-fill"></i>
                                </label>
                                <input type="file" name="file" id="fileInput" class="file-input" accept="image/*" />
                            </form>
                            <p class="text-muted small mt-2">Fotoğraf değiştirmek için kameraya tıklayın</p>
                        </div>
                    </div>
                    
                    <div class="card-body p-4 text-center">
                        @if (TempData["Basarili"] != null)
                        {
                            <div class="alert-custom alert-success-custom mb-3">@TempData["Basarili"]</div>
                        }
                        @if (TempData["Hata"] != null)
                        {
                            <div class="alert-custom alert-danger-custom mb-3">@TempData["Hata"]</div>
                        }
                        
                        <h3 class="fw-bold">@Model.AdSoyad</h3>
                        <p class="text-muted"><i class="bi bi-envelope me-1"></i> @Model.Email</p>
                        <p class="text-muted"><i class="bi bi-telephone me-1"></i> @Model.Telefon</p>
                        <p class="text-muted"><i class="bi bi-star me-1"></i> @Model.Uzmanlik</p>
                        <hr />
                        <div class="d-flex justify-content-center gap-3 flex-wrap">
                            <a href="@Url.Action("SifreDegistir", "Antrenor")" class="btn btn-outline-primary">
                                <i class="bi bi-key me-1"></i>Şifre Değiştir
                            </a>
                            <a href="@Url.Action("Panel", "Antrenor")" class="btn-custom">
                                <i class="bi bi-speedometer2 me-1"></i>Panele Git
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('uploadLabel').addEventListener('click', function() {
            document.getElementById('fileInput').click();
        });
        document.getElementById('fileInput').addEventListener('change', function() {
            if (this.files && this.files[0]) {
                document.getElementById('fotoForm').submit();
            }
        });
    </script>
</body>
</html>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Panel</title>
    <style>
        body { font-family: Arial; margin: 0; padding: 0; }
        .header { background: #0B2A4A; color: white; padding: 15px; text-align: center; }
        .container { padding: 20px; }
        button { background: #0B2A4A; color: white; padding: 10px 20px; border: none; margin: 5px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="header">
        <h2>BEYKENT SPOR - PANEL</h2>
        <p>Hoş geldin, @ViewBag.AntrenorAdi</p>
        <a href="/Antrenor/Cikis" style="color:white">Çıkış</a>
    </div>
    <div class="container">
        <h3>Giriş başarılı! ✅</h3>
        <p>Uygulama çalışıyor. Şimdi diğer özellikleri ekleyebiliriz.</p>
    </div>
</body>
</html>
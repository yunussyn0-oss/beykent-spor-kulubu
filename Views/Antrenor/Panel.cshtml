@model SporKulubu.Models.Antrenor

@{
    ViewData["Title"] = "Antrenör Paneli";
    var tamYetki = ViewBag.TamYetki ?? false;
}

<div class="container-fluid mt-4">
    <!-- Hoş Geldin Kartı -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-gradient-primary text-white shadow-lg">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <i class="bi bi-person-circle display-4 me-4"></i>
                            </div>
                            <div>
                                <h2 class="fw-bold mb-1">Hoş Geldin, @Model.AdSoyad</h2>
                                <p class="lead mb-0 fs-6 opacity-75">
                                    <i class="bi bi-trophy-fill me-1"></i>
                                    @if (tamYetki)
                                    {
                                        <span>Tüm Salonlar</span>
                                    }
                                    else
                                    {
                                        <span>Yetkili Salon</span>
                                    }
                                </p>
                                <div class="mt-2">
                                    <span class="badge bg-light text-dark me-2">
                                        <i class="bi bi-people-fill me-1"></i>@ViewBag.SporcuSayisi Sporcu
                                    </span>
                                    @if (ViewBag.SecilenSalonAdi != null)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-building me-1"></i>@ViewBag.SecilenSalonAdi
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                        <div>
                            <a asp-action="Cikis" class="btn btn-danger btn-lg px-4 py-3">
                                <i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Hızlı İşlem Kartları -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <a href="/Antrenor/Yoklama" class="text-decoration-none">
                <div class="card shadow-sm hover-card border-0">
                    <div class="card-body text-center p-4">
                        <div class="bg-success bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                            <i class="bi bi-check2-circle text-success fs-1"></i>
                        </div>
                        <h5 class="fw-bold mb-2">Yoklama Al</h5>
                        <p class="text-muted small mb-0">Antrenman yoklaması</p>
                        <span class="badge bg-success mt-3">Bugün Al</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Antrenor/VeliMesaj" class="text-decoration-none">
                <div class="card shadow-sm hover-card border-0">
                    <div class="card-body text-center p-4">
                        <div class="bg-info bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                            <i class="bi bi-chat-dots text-info fs-1"></i>
                        </div>
                        <h5 class="fw-bold mb-2">Veli Mesaj</h5>
                        <p class="text-muted small mb-0">Toplu WhatsApp/SMS</p>
                        <span class="badge bg-info mt-3">@ViewBag.SporcuSayisi Veli</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Antrenor/Istatistikler" class="text-decoration-none">
                <div class="card shadow-sm hover-card border-0">
                    <div class="card-body text-center p-4">
                        <div class="bg-warning bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                            <i class="bi bi-bar-chart-line text-warning fs-1"></i>
                        </div>
                        <h5 class="fw-bold mb-2">İstatistikler</h5>
                        <p class="text-muted small mb-0">Katılım raporları</p>
                        <span class="badge bg-warning text-dark mt-3">Detaylar</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Antrenor/GecmisYoklamalar" class="text-decoration-none">
                <div class="card shadow-sm hover-card border-0">
                    <div class="card-body text-center p-4">
                        <div class="bg-secondary bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                            <i class="bi bi-clock-history text-secondary fs-1"></i>
                        </div>
                        <h5 class="fw-bold mb-2">Geçmiş Yoklamalar</h5>
                        <p class="text-muted small mb-0">Önceki kayıtlar</p>
                        <span class="badge bg-secondary mt-3">Arşiv</span>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Filtreleme Kartı -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-funnel text-primary me-2"></i>
                        Filtreleme
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="Panel" method="get" class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold small text-uppercase text-muted">Spor Salonu</label>
                            <select name="salonId" class="form-select" id="salonFilter" asp-items="ViewBag.SporSalonlari">
                                <option value="">Tüm Salonlar</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold small text-uppercase text-muted">Takım</label>
                            <select name="takimId" class="form-select" id="takimFilter">
                                <option value="">Tüm Takımlar</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold small text-uppercase text-muted">Grup</label>
                            <select name="grupId" class="form-select" id="grupFilter">
                                <option value="">Tüm Gruplar</option>
                            </select>
                        </div>

                        <div class="col-12 text-end">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-search me-1"></i>Filtrele
                            </button>
                            <a asp-action="Panel" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-repeat me-1"></i>Temizle
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Sporcu Listesi (WhatsApp ve SMS Butonlu) -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0">
                            <i class="bi bi-people-fill text-primary me-2"></i>
                            Sporcu Listesi
                        </h5>
                        <div>
                            <span class="badge bg-primary me-2">@ViewBag.SporcuSayisi Sporcu</span>
                            <a href="/Antrenor/VeliMesaj" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-envelope-paper me-1"></i>Toplu Mesaj
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (ViewBag.Sporcular != null && ViewBag.Sporcular.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th width="50">#</th>
                                        <th>Ad Soyad</th>
                                        <th>Doğum Tarihi</th>
                                        <th>Salon</th>
                                        <th>Branş</th>
                                        <th>Takım</th>
                                        <th>Grup</th>
                                        <th>Veli Adı</th>
                                        <th>Veli Telefon</th>
                                        <th width="200">İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int index = 0;
                                    }
                                    @foreach (var uye in ViewBag.Sporcular)
                                    {
                                        index++;
                                        var temizTelefon = uye.VeliTelefon?.Replace(" ", "").Replace("(", "").Replace(")", "").Replace("-", "") ?? "";
                                        
                                        <tr>
                                            <td class="fw-bold">@index</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <i class="bi bi-person-circle text-primary me-2"></i>
                                                    <span class="fw-bold">@uye.AdSoyad</span>
                                                </div>
                                            </td>
                                            <td>@uye.DogumTarihi.ToShortDateString()</td>
                                            <td>
                                                <span class="badge bg-primary bg-opacity-10 text-primary p-2">
                                                    @(uye.SporSalonu?.Ad ?? "-")
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-success bg-opacity-10 text-success p-2">
                                                    @(uye.Brans?.Ad ?? "-")
                                                </span>
                                            </td>
                                            <td>
                                                @if (uye.Takim != null)
                                                {
                                                    <span class="badge bg-warning bg-opacity-10 text-warning p-2">
                                                        @uye.Takim.Ad
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary bg-opacity-10 text-secondary p-2">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (uye.Grup != null)
                                                {
                                                    <span class="badge bg-info bg-opacity-10 text-info p-2">
                                                        @uye.Grup.Ad
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary bg-opacity-10 text-secondary p-2">-</span>
                                                }
                                            </td>
                                            <td>@uye.VeliAdSoyad</td>
                                            <td>
                                                <span class="badge bg-info">
                                                    <i class="bi bi-telephone me-1"></i>@uye.VeliTelefon
                                                </span>
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <!-- Detaylı Veli İletişim Sayfası -->
                                                    <a asp-action="VeliDetay" asp-route-id="@uye.Id" 
                                                       class="btn btn-sm btn-info" 
                                                       title="Detaylı İletişim">
                                                        <i class="bi bi-chat-dots"></i>
                                                    </a>
                                                    
                                                    <!-- Hızlı WhatsApp -->
                                                    <a href="https://wa.me/@temizTelefon" 
                                                       target="_blank" 
                                                       class="btn btn-sm btn-success" 
                                                       title="WhatsApp">
                                                        <i class="bi bi-whatsapp"></i>
                                                    </a>
                                                    
                                                    <!-- Hızlı SMS (Mesaj önceden doldurulmuş) -->
                                                    <a href="sms:@uye.VeliTelefon?body=Sayın @uye.VeliAdSoyad, @uye.AdSoyad hakkında bilgilendirme yapmak istiyorum." 
                                                       class="btn btn-sm btn-primary" 
                                                       title="SMS">
                                                        <i class="bi bi-envelope-paper"></i>
                                                    </a>
                                                    
                                                    <!-- Telefon Kopyala -->
                                                    <button class="btn btn-sm btn-outline-secondary copy-phone" 
                                                            data-phone="@uye.VeliTelefon" 
                                                            title="Telefon Kopyala">
                                                        <i class="bi bi-files"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-people display-1 text-muted"></i>
                            <h4 class="mt-3 text-muted">Henüz sporcu bulunmuyor</h4>
                            <p class="text-muted">Filtrelemeyi değiştirerek farklı sporcuları görüntüleyebilirsiniz.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    .hover-card {
        transition: transform 0.3s, box-shadow 0.3s;
        cursor: pointer;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .badge {
        font-weight: 500;
    }
    .btn-group .btn {
        border-radius: 0;
    }
    .btn-group .btn:first-child {
        border-top-left-radius: 5px;
        border-bottom-left-radius: 5px;
    }
    .btn-group .btn:last-child {
        border-top-right-radius: 5px;
        border-bottom-right-radius: 5px;
    }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            // Sayfa yüklendiğinde seçili değerleri al
            var seciliSalonId = '@ViewBag.SecilenSalonId';
            var seciliTakimId = '@ViewBag.SecilenTakimId';
            var seciliGrupId = '@ViewBag.SecilenGrupId';

            // Takımları getir (Salon seçilince)
            function takimlariGetir(salonId, seciliTakimId) {
                if (salonId) {
                    $('#takimFilter').empty().append('<option value="">Yükleniyor...</option>');
                    $('#grupFilter').empty().append('<option value="">Tüm Gruplar</option>');
                    
                    $.getJSON('/Antrenor/TakimlariGetir', { salonId: salonId }, function(data) {
                        var takimSelect = $('#takimFilter');
                        takimSelect.empty().append('<option value="">Tüm Takımlar</option>');
                        if (data && data.length > 0) {
                            $.each(data, function(i, takim) {
                                var option = $('<option>').text(takim.ad).val(takim.id);
                                if (seciliTakimId && takim.id == seciliTakimId) {
                                    option.attr('selected', 'selected');
                                }
                                takimSelect.append(option);
                            });
                            
                            // Takım seçiliyse grupları da getir
                            if (seciliTakimId) {
                                gruplariGetir(seciliTakimId, seciliGrupId);
                            }
                        } else {
                            takimSelect.append('<option value="">Bu salonda takım yok</option>');
                        }
                    }).fail(function() {
                        $('#takimFilter').empty().append('<option value="">Hata oluştu</option>');
                    });
                } else {
                    $('#takimFilter').empty().append('<option value="">Tüm Takımlar</option>');
                    $('#grupFilter').empty().append('<option value="">Tüm Gruplar</option>');
                }
            }

            // Grupları getir (Takım seçilince)
            function gruplariGetir(takimId, seciliGrupId) {
                if (takimId) {
                    $('#grupFilter').empty().append('<option value="">Yükleniyor...</option>');
                    
                    $.getJSON('/Antrenor/GruplariGetir', { takimId: takimId }, function(data) {
                        var grupSelect = $('#grupFilter');
                        grupSelect.empty().append('<option value="">Tüm Gruplar</option>');
                        if (data && data.length > 0) {
                            $.each(data, function(i, grup) {
                                var option = $('<option>').text(grup.ad).val(grup.id);
                                if (seciliGrupId && grup.id == seciliGrupId) {
                                    option.attr('selected', 'selected');
                                }
                                grupSelect.append(option);
                            });
                        } else {
                            grupSelect.append('<option value="">Bu takımda grup yok</option>');
                        }
                    }).fail(function() {
                        $('#grupFilter').empty().append('<option value="">Hata oluştu</option>');
                    });
                } else {
                    $('#grupFilter').empty().append('<option value="">Tüm Gruplar</option>');
                }
            }

            // Salon değişince takımları getir
            $('#salonFilter').change(function() {
                var salonId = $(this).val();
                $('#takimFilter').empty().append('<option value="">Tüm Takımlar</option>');
                $('#grupFilter').empty().append('<option value="">Tüm Gruplar</option>');
                
                if (salonId) {
                    takimlariGetir(salonId, null);
                }
            });

            // Takım değişince grupları getir
            $('#takimFilter').change(function() {
                var takimId = $(this).val();
                $('#grupFilter').empty().append('<option value="">Tüm Gruplar</option>');
                
                if (takimId) {
                    gruplariGetir(takimId, null);
                }
            });

            // Sayfa yüklendiğinde seçili salon varsa takımları getir
            if (seciliSalonId && seciliSalonId !== '') {
                $('#salonFilter').val(seciliSalonId);
                takimlariGetir(seciliSalonId, seciliTakimId);
                
                // Seçili takım varsa onu ayarla
                if (seciliTakimId && seciliTakimId !== '') {
                    setTimeout(function() {
                        $('#takimFilter').val(seciliTakimId).trigger('change');
                    }, 300);
                }
            }

            // Telefon kopyalama işlevi
            $('.copy-phone').click(function() {
                var phone = $(this).data('phone');
                navigator.clipboard.writeText(phone).then(function() {
                    // Toast bildirimi göster
                    var toast = document.createElement('div');
                    toast.className = 'position-fixed bottom-0 end-0 m-3';
                    toast.innerHTML = '<div class="alert alert-success alert-dismissible fade show">' +
                        '<i class="bi bi-check-circle-fill me-2"></i>Telefon numarası kopyalandı: ' + phone +
                        '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
                    document.body.appendChild(toast);
                    setTimeout(() => toast.remove(), 3000);
                });
            });
        });
    </script>
}
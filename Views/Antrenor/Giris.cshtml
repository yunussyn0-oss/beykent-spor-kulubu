@{
    ViewData["Title"] = "Antrenör Girişi";
    var salonId = ViewBag.GirisSalonId;
    var salonAdi = ViewBag.GirisSalonAdi ?? "Beykent Spor Kulübü";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Beykent Spor</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: linear-gradient(145deg, #0B2A4A 0%, #1B3B5C 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        .login-container {
            max-width: 450px;
            margin: 0 auto;
            width: 90%;
        }
        .login-card {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            border-radius: 32px;
            padding: 2.5rem 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .login-header {
            text-align: center;
            margin-bottom: 2.5rem;
        }
        .login-header .logo {
            width: 100px;
            height: 100px;
            background: linear-gradient(145deg, #0B2A4A, #1B3B5C);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
        }
        .login-header .logo i {
            font-size: 3.5rem;
            color: white;
        }
        .login-header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: #0B2A4A;
            margin-bottom: 0.5rem;
        }
        .login-header p {
            color: #6B7A8F;
            font-size: 1rem;
            margin: 0;
        }
        .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            color: #0B2A4A;
            margin-bottom: 0.5rem;
        }
        .input-group {
            border: 2px solid #E5E9F0;
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s;
            background: white;
        }
        .input-group:focus-within {
            border-color: #0B2A4A;
        }
        .input-group-text {
            background: white;
            border: none;
            padding: 0.75rem 1rem;
            color: #0B2A4A;
        }
        .form-control {
            border: none;
            padding: 0.75rem 1rem 0.75rem 0.5rem;
            font-size: 1rem;
        }
        .form-control:focus {
            outline: none;
            box-shadow: none;
        }
        .btn-login {
            background: linear-gradient(145deg, #0B2A4A, #1B3B5C);
            border: none;
            border-radius: 16px;
            padding: 1rem;
            font-weight: 600;
            font-size: 1.1rem;
            color: white;
            width: 100%;
            transition: all 0.3s;
            margin-top: 1rem;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 30px -10px rgba(11, 42, 74, 0.4);
        }
        .alert-custom {
            border-radius: 16px;
            padding: 1rem;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .alert-danger-custom {
            background: #FEF2F2;
            color: #991B1B;
            border-left: 4px solid #DC2626;
        }
        .badge-salon {
            background: rgba(11, 42, 74, 0.1);
            color: #0B2A4A;
            padding: 0.5rem 1rem;
            border-radius: 100px;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin-top: 1rem;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="logo">
                    <i class="bi bi-shield-shaded"></i>
                </div>
                <h1>BEYKENT SPOR</h1>
                <p>Antrenör Giriş Paneli</p>
                @if (salonId.HasValue && !string.IsNullOrEmpty(salonAdi))
                {
                    <div class="badge-salon">
                        <i class="bi bi-building"></i>
                        @salonAdi
                    </div>
                }
            </div>

            @if (ViewBag.Hata != null)
            {
                <div class="alert-custom alert-danger-custom">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div>
                        <strong>Giriş Başarısız</strong><br />
                        @ViewBag.Hata
                    </div>
                </div>
            }

            <form method="post" action="/Antrenor/Giris" id="loginForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="salonId" value="@salonId" />

                <div class="mb-4">
                    <label class="form-label">
                        <i class="bi bi-envelope-fill me-2"></i>E-POSTA
                    </label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-envelope-fill"></i>
                        </span>
                        <input type="email" name="email" class="form-control" 
                               placeholder="ornek@beykentspor.com" 
                               value="burhan@beykentspor.com" required />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">
                        <i class="bi bi-lock-fill me-2"></i>ŞİFRE
                    </label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-lock-fill"></i>
                        </span>
                        <input type="password" name="sifre" class="form-control" 
                               placeholder="••••••••" value="123456" required />
                    </div>
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right me-2"></i>GİRİŞ YAP
                </button>
            </form>
        </div>
    </div>
</body>
</html>
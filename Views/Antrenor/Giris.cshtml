@{
    ViewData["Title"] = "Antrenör Girişi";
    var salonId = ViewBag.GirisSalonId;
    var salonAdi = ViewBag.GirisSalonAdi;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Üst Gradient Banner -->
                <div class="bg-gradient-primary text-white text-center py-5 px-4">
                    <i class="bi bi-person-badge-fill display-1 mb-3"></i>
                    <h2 class="fw-bold mb-0">Antrenör Girişi</h2>
                    <p class="opacity-75 mb-0">@salonAdi</p>
                    
                    @if (salonId != null)
                    {
                        <div class="mt-3">
                            <span class="badge bg-warning text-dark p-2">
                                <i class="bi bi-building me-1"></i>@salonAdi
                            </span>
                        </div>
                    }
                </div>

                <!-- Giriş Formu -->
                <div class="card-body p-5">
                    @if (TempData["Hata"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @TempData["Hata"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    
                    @if (ViewBag.Hata != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @ViewBag.Hata
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["Basarili"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            @TempData["Basarili"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Giris" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="salonId" value="@salonId" />
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase">
                                <i class="bi bi-envelope-fill me-2"></i>E-posta Adresi
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light border-0">
                                    <i class="bi bi-envelope-fill text-primary"></i>
                                </span>
                                <input type="email" name="email" class="form-control border-0 border-bottom rounded-0 ps-0" 
                                       placeholder="ornek@beykentspor.com" value="burhan@beykentspor.com" required />
                            </div>
                        </div>

                        <div class="mb-5">
                            <label class="form-label fw-bold text-muted small text-uppercase">
                                <i class="bi bi-lock-fill me-2"></i>Şifre
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light border-0">
                                    <i class="bi bi-lock-fill text-primary"></i>
                                </span>
                                <input type="password" name="sifre" class="form-control border-0 border-bottom rounded-0 ps-0" 
                                       placeholder="••••••••" value="123456" required />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 py-3 mb-3 rounded-3 fw-bold">
                            <i class="bi bi-box-arrow-in-right me-2"></i>GİRİŞ YAP
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted small mb-0">
                            <i class="bi bi-shield-lock me-1"></i>
                            Yetkili antrenörler içindir.
                        </p>
                        @if (salonId != null)
                        {
                            <p class="text-muted small mt-2">
                                <i class="bi bi-building me-1"></i>
                                <strong>@salonAdi</strong> için giriş yapıyorsunuz.
                            </p>
                        }
                    </div>
                </div>
            </div>

            <!-- Geri Dön Butonu -->
            <div class="text-center mt-4">
                <a href="/" class="text-decoration-none text-muted">
                    <i class="bi bi-arrow-left me-1"></i>Ana Sayfaya Dön
                </a>
            </div>

            <!-- Test Bilgileri -->
            <div class="card mt-4 border-0 bg-light">
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-2"><i class="bi bi-info-circle me-2"></i>Test Giriş Bilgileri</h6>
                    <div class="row small">
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Tam Yetki:</strong></p>
                            <p class="mb-1">burhan@beykentspor.com / 123456</p>
                            <p class="mb-1">ertan@beykentspor.com / 123456</p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Yakuplu:</strong></p>
                            <p class="mb-1">ozgur@beykentspor.com / 123456</p>
                            <p class="mb-1">eftelya@beykentspor.com / 123456</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    .input-group-text {
        border-radius: 10px 0 0 10px;
    }
    .form-control:focus {
        box-shadow: none;
        border-bottom: 2px solid #0d6efd !important;
    }
    .btn-primary {
        transition: all 0.3s;
    }
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(13, 110, 253, 0.3);
    }
</style>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş - Beylikdüzü Beykent Spor Kulübü</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: linear-gradient(135deg, #0B2A4A 0%, #1B3B5C 50%, #2C4A6E 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: white;
            border-radius: 24px;
            padding: 40px;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
        }
        .logo {
            text-align: center;
            margin-bottom: 30px;
        }
        .logo i {
            font-size: 60px;
            color: #FFD700;
            background: #0B2A4A;
            padding: 20px;
            border-radius: 50%;
        }
        .logo h1 {
            color: #0B2A4A;
            font-size: 24px;
            margin-top: 20px;
            font-weight: 700;
        }
        .logo p {
            color: #6B7A8F;
            font-size: 14px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            font-weight: 600;
            color: #0B2A4A;
            margin-bottom: 8px;
            display: block;
        }
        .input-group {
            border: 2px solid #e1e5e9;
            border-radius: 12px;
            transition: all 0.3s;
        }
        .input-group:focus-within {
            border-color: #0B2A4A;
        }
        .input-group-text {
            background: white;
            border: none;
            color: #0B2A4A;
        }
        .form-control {
            border: none;
            padding: 12px 0;
        }
        .form-control:focus {
            outline: none;
            box-shadow: none;
        }
        .btn-login {
            background: linear-gradient(135deg, #0B2A4A, #1B3B5C);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 600;
            width: 100%;
            margin-top: 10px;
            transition: all 0.3s;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(11,42,74,0.3);
        }
        .error {
            background: #f8d7da;
            color: #721c24;
            padding: 12px;
            border-radius: 12px;
            margin-bottom: 20px;
            text-align: center;
        }
        .test-info {
            background: #f0f4f8;
            border-radius: 16px;
            padding: 15px;
            margin-top: 25px;
        }
        .test-info h6 {
            color: #0B2A4A;
            font-weight: 700;
            margin-bottom: 10px;
        }
        .test-item {
            font-size: 12px;
            padding: 5px 0;
            border-bottom: 1px solid #ddd;
        }
        .test-item:last-child {
            border-bottom: none;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo">
            <i class="bi bi-trophy-fill"></i>
            <h1>BEYLİKDÜZÜ BEYKENT SPOR</h1>
            <p>Antrenör Giriş Paneli</p>
        </div>

        @if (ViewBag.Hata != null)
        {
            <div class="error">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Hata
            </div>
        }

        <form method="post" action="@Url.Action("Giris", "Antrenor")">
            <div class="form-group">
                <label><i class="bi bi-envelope-fill me-2"></i>E-posta Adresi</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
                    <input type="email" name="email" class="form-control" placeholder="ornek@bbsk.com" required />
                </div>
            </div>

            <div class="form-group">
                <label><i class="bi bi-lock-fill me-2"></i>Şifre</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                    <input type="password" name="sifre" class="form-control" placeholder="••••••••" required />
                </div>
            </div>

            <button type="submit" class="btn-login">
                <i class="bi bi-box-arrow-in-right me-2"></i>GİRİŞ YAP
            </button>
        </form>

        <div class="test-info">
            <h6><i class="bi bi-info-circle-fill me-2"></i>Test Giriş Bilgileri</h6>
            <div class="test-item">👑 burhansayan@bbsk.com / 123456</div>
            <div class="test-item">👑 ertantuncel@bbsk.com / 123456</div>
            <div class="test-item">🏋️ ozgurdemir@bbsk.com / 123456</div>
            <div class="test-item">🏢 sezeryilmaz@bbsk.com / 123456</div>
            <div class="test-item">🏠 nesrinkaya@bbsk.com / 123456</div>
        </div>
    </div>
</body>
</html>
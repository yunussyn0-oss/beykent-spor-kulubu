@{
    ViewData["Title"] = "Antrenör Girişi";
    var salonId = ViewBag.GirisSalonId;
    var salonAdi = ViewBag.GirisSalonAdi ?? "Beykent Spor Kulübü";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Beykent Spor</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: linear-gradient(145deg, #0B2A4A 0%, #1B3B5C 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }

        .login-container {
            max-width: 450px;
            margin: 0 auto;
            width: 90%;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            border-radius: 32px;
            padding: 2.5rem 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .login-header {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .login-header .logo {
            width: 100px;
            height: 100px;
            background: linear-gradient(145deg, #0B2A4A, #1B3B5C);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            box-shadow: 0 20px 30px -10px rgba(11, 42, 74, 0.3);
        }

        .login-header .logo i {
            font-size: 3.5rem;
            color: white;
        }

        .login-header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: #0B2A4A;
            margin-bottom: 0.5rem;
        }

        .login-header p {
            color: #6B7A8F;
            font-size: 1rem;
            margin: 0;
        }

        .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #0B2A4A;
            margin-bottom: 0.5rem;
        }

        .input-group {
            border: 2px solid #E5E9F0;
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s ease;
            background: white;
        }

        .input-group:focus-within {
            border-color: #0B2A4A;
            box-shadow: 0 4px 12px rgba(11, 42, 74, 0.1);
        }

        .input-group-text {
            background: white;
            border: none;
            padding: 0.75rem 1rem;
            color: #0B2A4A;
        }

        .form-control {
            border: none;
            padding: 0.75rem 1rem 0.75rem 0.5rem;
            font-size: 1rem;
            background: white;
        }

        .form-control:focus {
            outline: none;
            box-shadow: none;
        }

        .password-toggle {
            background: white;
            border: none;
            padding: 0.75rem 1rem;
            color: #6B7A8F;
            cursor: pointer;
            transition: color 0.2s;
        }

        .password-toggle:hover {
            color: #0B2A4A;
        }

        .btn-login {
            background: linear-gradient(145deg, #0B2A4A, #1B3B5C);
            border: none;
            border-radius: 16px;
            padding: 1rem;
            font-weight: 600;
            font-size: 1.1rem;
            color: white;
            width: 100%;
            transition: all 0.3s;
            margin-top: 1rem;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 30px -10px rgba(11, 42, 74, 0.4);
            background: linear-gradient(145deg, #1B3B5C, #0B2A4A);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .alert-custom {
            border-radius: 16px;
            padding: 1rem;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            border: none;
        }

        .alert-danger-custom {
            background: #FEF2F2;
            color: #991B1B;
            border-left: 4px solid #DC2626;
        }

        .alert-success-custom {
            background: #F0FDF4;
            color: #166534;
            border-left: 4px solid #16A34A;
        }

        .alert i {
            font-size: 1.5rem;
        }

        .test-card {
            background: white;
            border-radius: 20px;
            padding: 1.5rem;
            margin-top: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.2);
        }

        .test-card-title {
            font-weight: 600;
            color: white;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .test-card-title i {
            font-size: 1.2rem;
        }

        .test-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .test-item {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 14px;
            padding: 1rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(5px);
        }

        .test-item-label {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }

        .test-item-value {
            color: white;
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 0.25rem;
        }

        .test-item-value small {
            color: #FFD700;
            font-weight: 400;
        }

        .back-link {
            text-align: center;
            margin-top: 2rem;
        }

        .back-link a {
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            font-size: 0.95rem;
            transition: color 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .back-link a:hover {
            color: white;
        }

        .badge-salon {
            background: rgba(11, 42, 74, 0.1);
            color: #0B2A4A;
            padding: 0.5rem 1rem;
            border-radius: 100px;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin-top: 1rem;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <!-- Header -->
            <div class="login-header">
                <div class="logo">
                    <i class="bi bi-shield-shaded"></i>
                </div>
                <h1>BEYKENT SPOR</h1>
                <p>Antrenör Giriş Paneli</p>
                @if (salonId.HasValue)
                {
                    <div class="badge-salon">
                        <i class="bi bi-building"></i>
                        @salonAdi
                    </div>
                }
            </div>

            <!-- Hata Mesajları -->
            @if (ViewBag.Hata != null)
            {
                <div class="alert-custom alert-danger-custom">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div>
                        <strong>Giriş Başarısız</strong><br />
                        @ViewBag.Hata
                    </div>
                </div>
            }

            @if (TempData["Hata"] != null)
            {
                <div class="alert-custom alert-danger-custom">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div>
                        <strong>Giriş Başarısız</strong><br />
                        @TempData["Hata"]
                    </div>
                </div>
            }

            @if (TempData["Basarili"] != null)
            {
                <div class="alert-custom alert-success-custom">
                    <i class="bi bi-check-circle-fill"></i>
                    <div>
                        <strong>Başarılı</strong><br />
                        @TempData["Basarili"]
                    </div>
                </div>
            }

            <!-- Giriş Formu -->
            <form method="post" action="/Antrenor/Giris" id="loginForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="salonId" value="@salonId" />

                <!-- Email -->
                <div class="mb-4">
                    <label class="form-label">
                        <i class="bi bi-envelope-fill me-2"></i>E-POSTA
                    </label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-envelope-fill"></i>
                        </span>
                        <input type="email" 
                               name="email" 
                               class="form-control" 
                               placeholder="ornek@beykentspor.com" 
                               value="burhan@beykentspor.com" 
                               required 
                               autocomplete="email" />
                    </div>
                </div>

                <!-- Şifre -->
                <div class="mb-4">
                    <label class="form-label">
                        <i class="bi bi-lock-fill me-2"></i>ŞİFRE
                    </label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-lock-fill"></i>
                        </span>
                        <input type="password" 
                               name="sifre" 
                               id="sifre" 
                               class="form-control" 
                               placeholder="••••••••" 
                               value="123456" 
                               required 
                               autocomplete="current-password" />
                        <button type="button" class="password-toggle" onclick="togglePassword()">
                            <i class="bi bi-eye" id="toggleIcon"></i>
                        </button>
                    </div>
                </div>

                <!-- Giriş Butonu -->
                <button type="submit" class="btn-login" id="loginButton">
                    <span class="button-text">
                        <i class="bi bi-box-arrow-in-right me-2"></i>GİRİŞ YAP
                    </span>
                </button>
            </form>
        </div>

        <!-- Test Bilgileri -->
        <div class="test-card">
            <div class="test-card-title">
                <i class="bi bi-info-circle-fill"></i>
                <span>Test Giriş Bilgileri</span>
            </div>
            <div class="test-grid">
                <div class="test-item">
                    <div class="test-item-label">Tam Yetkili</div>
                    <div class="test-item-value">burhan@beykentspor.com</div>
                    <div class="test-item-value">ertan@beykentspor.com</div>
                    <div class="test-item-value"><small>Şifre: 123456</small></div>
                </div>
                <div class="test-item">
                    <div class="test-item-label">Yakuplu</div>
                    <div class="test-item-value">ozgur@beykentspor.com</div>
                    <div class="test-item-value">eftelya@beykentspor.com</div>
                    <div class="test-item-value"><small>Şifre: 123456</small></div>
                </div>
            </div>
        </div>

        <!-- Geri Link -->
        <div class="back-link">
            <a href="/">
                <i class="bi bi-arrow-left"></i>
                Ana Sayfaya Dön
            </a>
        </div>
    </div>

    <script>
        // Şifre göster/gizle
        function togglePassword() {
            var sifre = document.getElementById('sifre');
            var icon = document.getElementById('toggleIcon');
            
            if (sifre.type === 'password') {
                sifre.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                sifre.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }

        // Enter tuşu ile form gönderme
        document.getElementById('loginForm').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                document.getElementById('loginForm').submit();
            }
        });
    </script>
</body>
</html>
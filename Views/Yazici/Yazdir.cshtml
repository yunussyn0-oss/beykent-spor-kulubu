@model IEnumerable<SporKulubu.Models.Uye>

@{
    ViewData["Title"] = "Yazdırılabilir Liste";
    Layout = null; // Layout kullanma, direkt yazdırmaya uygun olsun
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Beykent Spor</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: white;
            padding: 20px;
            color: #333;
        }

        .print-container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 3px solid #0B2A4A;
        }

        .header-left h1 {
            color: #0B2A4A;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .header-left p {
            color: #666;
            font-size: 14px;
        }

        .header-right {
            text-align: right;
        }

        .header-right .date {
            color: #0B2A4A;
            font-weight: 600;
            font-size: 16px;
        }

        .header-right .filter {
            color: #666;
            font-size: 14px;
            margin-top: 5px;
        }

        .stats {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            flex: 1;
            background: #f8f9fa;
            border-radius: 10px;
            padding: 15px;
            border-left: 4px solid #0B2A4A;
        }

        .stat-label {
            color: #666;
            font-size: 13px;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        .stat-value {
            color: #0B2A4A;
            font-size: 24px;
            font-weight: 700;
        }

        .table-container {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 0 20px rgba(0,0,0,0.05);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            background: #0B2A4A;
            color: white;
            padding: 12px 8px;
            text-align: left;
            font-weight: 600;
            white-space: nowrap;
        }

        td {
            padding: 10px 8px;
            border-bottom: 1px solid #e9ecef;
            color: #333;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover {
            background: #f8f9fa;
        }

        .badge {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-salon {
            background: #e7f1ff;
            color: #0B2A4A;
        }

        .badge-brans {
            background: #e6f7e6;
            color: #28a745;
        }

        .badge-takim {
            background: #fff3cd;
            color: #856404;
        }

        .badge-grup {
            background: #d1ecf1;
            color: #0c5460;
        }

        .badge-aidat {
            background: #f8d7da;
            color: #721c24;
        }

        .footer {
            margin-top: 30px;
            text-align: center;
            color: #999;
            font-size: 12px;
            padding-top: 20px;
            border-top: 1px solid #e9ecef;
        }

        .no-data {
            text-align: center;
            padding: 50px;
            color: #999;
        }

        @@media print {
            body {
                padding: 0;
            }
            .no-print {
                display: none;
            }
        }

        .print-button {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #0B2A4A;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 50px;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(11,42,74,0.3);
            z-index: 1000;
        }

        .print-button:hover {
            background: #1B3B5C;
        }
    </style>
</head>
<body>
    <div class="print-container">
        <!-- Header -->
        <div class="header">
            <div class="header-left">
                <h1>BEYKENT SPOR KULÜBÜ</h1>
                <p><i class="bi bi-people"></i> Sporcu Listesi</p>
            </div>
            <div class="header-right">
                <div class="date">@ViewBag.Tarih</div>
                @if (!string.IsNullOrEmpty(ViewBag.FiltreBilgi))
                {
                    <div class="filter">Filtre: @ViewBag.FiltreBilgi</div>
                }
            </div>
        </div>

        <!-- İstatistikler -->
        <div class="stats">
            <div class="stat-card">
                <div class="stat-label">Toplam Sporcu</div>
                <div class="stat-value">@ViewBag.ToplamKayit</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Toplam Aidat</div>
                <div class="stat-value">@ViewBag.ToplamAidat.ToString("C")</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Borçlu Sayısı</div>
                <div class="stat-value">@ViewBag.BorcluSayisi</div>
            </div>
        </div>

        <!-- Tablo -->
        <div class="table-container">
            @if (Model.Any())
            {
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Ad Soyad</th>
                            <th>Telefon</th>
                            <th>Doğum Tarihi</th>
                            <th>Salon</th>
                            <th>Branş</th>
                            <th>Takım</th>
                            <th>Grup</th>
                            <th>Aylık Aidat</th>
                            <th>Kıyafet</th>
                            <th>Veli Adı</th>
                            <th>Veli Telefon</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int sayac = 1;
                        }
                        @foreach (var uye in Model)
                        {
                            <tr>
                                <td><strong>@sayac</strong></td>
                                <td><strong>@uye.AdSoyad</strong></td>
                                <td>@uye.Telefon</td>
                                <td>@uye.DogumTarihi.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <span class="badge badge-salon">@(uye.SporSalonu?.Ad ?? "-")</span>
                                </td>
                                <td>
                                    <span class="badge badge-brans">@(uye.Brans?.Ad ?? "-")</span>
                                </td>
                                <td>
                                    <span class="badge badge-takim">@(uye.Takim?.Ad ?? "-")</span>
                                </td>
                                <td>
                                    <span class="badge badge-grup">@(uye.Grup?.Ad ?? "-")</span>
                                </td>
                                <td><strong>@uye.AylikAidat.ToString("C")</strong></td>
                                <td>
                                    @if (uye.KiyafetVerildiMi)
                                    {
                                        <span class="badge" style="background: #d4edda; color: #155724;">✓ Verildi</span>
                                    }
                                    else
                                    {
                                        <span class="badge" style="background: #f8d7da; color: #721c24;">✗ Verilmedi</span>
                                    }
                                </td>
                                <td>@uye.VeliAdSoyad</td>
                                <td>@uye.VeliTelefon</td>
                            </tr>
                            sayac++;
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="no-data">
                    <h3>Listelenecek sporcu bulunamadı.</h3>
                    <p>Farklı filtreler deneyin veya yeni sporcu ekleyin.</p>
                </div>
            }
        </div>

        <!-- Footer -->
        <div class="footer">
            <p>© @DateTime.Now.Year Beykent Spor Kulübü - Tüm hakları saklıdır.</p>
            <p>Bu belge otomatik olarak oluşturulmuştur.</p>
        </div>
    </div>

    <!-- Yazdır Butonu -->
    <button class="print-button no-print" onclick="window.print()">
        <i class="bi bi-printer me-2"></i>Yazdır / PDF Olarak Kaydet
    </button>

    <script>
        // Sayfa yüklendiğinde yazdırma penceresini açmak isterseniz
        // window.onload = function() { window.print(); }
    </script>
</body>
</html>
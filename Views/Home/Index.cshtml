@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container-fluid mt-4">
    <!-- HERO BÖLÜMÜ (Büyük Giriş Kartı) -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="bg-gradient-primary text-white rounded-5 p-5 shadow-lg position-relative overflow-hidden">
                <!-- Arka plan deseni -->
                <div class="position-absolute top-0 end-0 opacity-10">
                    <i class="bi bi-trophy-fill" style="font-size: 15rem;"></i>
                </div>
                
                <div class="row align-items-center position-relative">
                    <div class="col-lg-8">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-white bg-opacity-20 rounded-circle p-3 me-3">
                                <i class="bi bi-trophy-fill text-warning fs-1"></i>
                            </div>
                            <div>
                                <h1 class="display-3 fw-bold mb-0">Beykent Spor</h1>
                                <p class="lead fs-4 mb-0 opacity-90">Profesyonel Sporcu Yönetim Sistemi</p>
                            </div>
                        </div>
                        
                        <p class="fs-5 mb-4 opacity-80">
                            <i class="bi bi-check-circle-fill me-2 text-warning"></i>
                            Sporcu kayıtları, aidat takibi, yoklama sistemi ve daha fazlası...
                        </p>
                        
                        <div class="d-flex gap-3 flex-wrap">
                            <a asp-controller="Uyeler" asp-action="Ekle" class="btn btn-warning btn-lg px-4 shadow">
                                <i class="bi bi-person-plus-fill me-2"></i>Yeni Sporcu Ekle
                            </a>
                            <a asp-controller="Uyeler" asp-action="Index" class="btn btn-outline-light btn-lg px-4 shadow">
                                <i class="bi bi-people-fill me-2"></i>Tüm Sporcular
                            </a>
                            <a asp-controller="Excel" asp-action="UyeleriExcelAktar" class="btn btn-success btn-lg px-4 shadow">
                                <i class="bi bi-file-earmark-excel me-2"></i>Excel Rapor
                            </a>
                        </div>
                    </div>
                    
                    <div class="col-lg-4 text-center d-none d-lg-block">
                        <div class="p-4 bg-white bg-opacity-10 rounded-4">
                            <i class="bi bi-people-fill display-1 text-warning"></i>
                            <h3 class="text-white mt-3">@ViewBag.ToplamUye</h3>
                            <p class="text-white-50 mb-0">Toplam Sporcu</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- İSTATİSTİK KARTLARI -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 hover-card">
                <div class="card-body text-center p-4">
                    <div class="bg-primary bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                        <i class="bi bi-people-fill text-primary fs-1"></i>
                    </div>
                    <h3 class="fw-bold mb-1">@ViewBag.ToplamUye</h3>
                    <p class="text-muted mb-2">Toplam Sporcu</p>
                    <a asp-controller="Uyeler" asp-action="Index" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-arrow-right me-1"></i>Listele
                    </a>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 hover-card">
                <div class="card-body text-center p-4">
                    <div class="bg-success bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                        <i class="bi bi-building text-success fs-1"></i>
                    </div>
                    <h3 class="fw-bold mb-1">@ViewBag.ToplamSalon</h3>
                    <p class="text-muted mb-2">Spor Salonu</p>
                    <span class="btn btn-sm btn-outline-success disabled">
                        <i class="bi bi-info-circle me-1"></i>3 Salon
                    </span>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 hover-card">
                <div class="card-body text-center p-4">
                    <div class="bg-info bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                        <i class="bi bi-grid-3x3-gap-fill text-info fs-1"></i>
                    </div>
                    <h3 class="fw-bold mb-1">@ViewBag.ToplamTakim</h3>
                    <p class="text-muted mb-2">Takım</p>
                    <span class="btn btn-sm btn-outline-info disabled">
                        <i class="bi bi-grid me-1"></i>4 Kategori
                    </span>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 hover-card border-danger">
                <div class="card-body text-center p-4">
                    <div class="bg-danger bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                        <i class="bi bi-exclamation-triangle-fill text-danger fs-1"></i>
                    </div>
                    <h3 class="fw-bold mb-1">@ViewBag.BorcluUye</h3>
                    <p class="text-muted mb-2">Borçlu Sporcu</p>
                    <a asp-controller="Uyeler" asp-action="BorcluUyeler" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-arrow-right me-1"></i>İncele
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- SPOR SALONLARI KARTLARI (Tıklanabilir - DOĞRUDAN ÜYE LİSTESİNE GİDER) -->
    <h2 class="fw-bold mb-4 position-relative pb-3">
        <i class="bi bi-building me-2 text-primary"></i>
        Spor Salonlarımız
        <span class="position-absolute bottom-0 start-0 w-25 bg-primary rounded" style="height: 4px;"></span>
    </h2>

    <div class="row g-4 mb-5">
        @if (ViewBag.SporSalonlari != null && ViewBag.SporSalonlari.Count > 0)
        {
            @foreach (var salon in ViewBag.SporSalonlari)
            {
                <div class="col-md-4">
                    <a href="/Uyeler?salonId=@salon.Id" class="text-decoration-none">
                        <div class="card border-0 shadow-sm hover-card h-100">
                            <div class="card-body text-center p-4">
                                <div class="bg-primary bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                                    <i class="bi bi-building fs-1 text-primary"></i>
                                </div>
                                <h4 class="fw-bold text-dark mb-3">@salon.Ad</h4>
                                
                                <div class="d-flex justify-content-center gap-2 mb-3">
                                    <span class="badge bg-primary bg-opacity-10 text-primary p-2">
                                        <i class="bi bi-people me-1"></i>Sporcular
                                    </span>
                                    <span class="badge bg-success bg-opacity-10 text-success p-2">
                                        <i class="bi bi-grid me-1"></i>Takımlar
                                    </span>
                                </div>
                                
                                <span class="btn btn-outline-primary btn-sm w-100">
                                    <i class="bi bi-eye me-1"></i>Salonu Görüntüle
                                </span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center py-5">
                    <i class="bi bi-info-circle-fill fs-1 d-block mb-3"></i>
                    <h4>Henüz spor salonu eklenmemiş</h4>
                    <p class="mb-3">Örnek verileri yükleyerek başlayabilirsiniz.</p>
                    <a asp-controller="Uyeler" asp-action="OrnekVeriEkle" class="btn btn-primary">
                        <i class="bi bi-database-fill me-2"></i>Örnek Verileri Yükle
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- HIZLI İŞLEMLER ve BİLGİ PANELİ -->
    <div class="row g-4">
        <!-- Hızlı İşlemler -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-lightning-charge-fill text-warning me-2"></i>
                        Hızlı İşlemler
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <a asp-controller="Uyeler" asp-action="Ekle" class="btn btn-outline-primary w-100 py-3">
                                <i class="bi bi-person-plus-fill fs-4 d-block mb-2"></i>
                                <span>Yeni Sporcu Ekle</span>
                            </a>
                        </div>
                        <div class="col-sm-6">
                            <a asp-controller="Uyeler" asp-action="Index" class="btn btn-outline-info w-100 py-3">
                                <i class="bi bi-people-fill fs-4 d-block mb-2"></i>
                                <span>Sporcu Listesi</span>
                            </a>
                        </div>
                        <div class="col-sm-6">
                            <a asp-controller="Uyeler" asp-action="BorcluUyeler" class="btn btn-outline-warning w-100 py-3">
                                <i class="bi bi-exclamation-triangle-fill fs-4 d-block mb-2"></i>
                                <span>Borçlu Üyeler</span>
                            </a>
                        </div>
                        <div class="col-sm-6">
                            <a asp-controller="Excel" asp-action="UyeleriExcelAktar" class="btn btn-outline-success w-100 py-3">
                                <i class="bi bi-file-earmark-excel fs-4 d-block mb-2"></i>
                                <span>Excel Rapor</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Bilgi ve İletişim -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-info-circle text-info me-2"></i>
                        Kulüp Bilgileri
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-info bg-opacity-10 rounded-circle p-3 me-3">
                            <i class="bi bi-geo-alt-fill text-info fs-4"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Adres</h6>
                            <p class="text-muted mb-0">Beylikdüzü / İstanbul</p>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-success bg-opacity-10 rounded-circle p-3 me-3">
                            <i class="bi bi-telephone-fill text-success fs-4"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">İletişim</h6>
                            <p class="text-muted mb-0">0 (212) 123 45 67</p>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-center">
                        <div class="bg-warning bg-opacity-10 rounded-circle p-3 me-3">
                            <i class="bi bi-envelope-fill text-warning fs-4"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">E-posta</h6>
                            <p class="text-muted mb-0">info@beykentspor.com</p>
                        </div>
                    </div>
                    
                    <hr class="my-4" />
                    
                    <div class="d-flex justify-content-around">
                        <div class="text-center">
                            <h4 class="fw-bold text-primary">@ViewBag.ToplamUye</h4>
                            <small class="text-muted">Sporcu</small>
                        </div>
                        <div class="text-center">
                            <h4 class="fw-bold text-success">@ViewBag.ToplamTakim</h4>
                            <small class="text-muted">Takım</small>
                        </div>
                        <div class="text-center">
                            <h4 class="fw-bold text-info">@ViewBag.ToplamGrup</h4>
                            <small class="text-muted">Grup</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SON EKLENEN ÜYELER (Widget) -->
    @if (ViewBag.SonUyeler != null && ViewBag.SonUyeler.Count > 0)
    {
        <div class="row mt-5">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white border-0 py-3">
                        <h5 class="fw-bold mb-0">
                            <i class="bi bi-clock-history text-primary me-2"></i>
                            Son Eklenen Sporcular
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            @foreach (var uye in ViewBag.SonUyeler)
                            {
                                <div class="col-md-6 col-lg-4">
                                    <div class="d-flex align-items-center p-3 bg-light rounded-3">
                                        <div class="flex-shrink-0">
                                            <i class="bi bi-person-circle fs-1 text-primary"></i>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <h6 class="fw-bold mb-1">@uye.AdSoyad</h6>
                                            <p class="small text-muted mb-1">
                                                <i class="bi bi-building me-1"></i>@(uye.SporSalonu?.Ad ?? "-")
                                            </p>
                                            <p class="small text-muted mb-0">
                                                <i class="bi bi-calendar me-1"></i>@uye.KayitTarihi.ToShortDateString()
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    .bg-opacity-20 {
        --bs-bg-opacity: 0.2;
    }
    .opacity-80 {
        opacity: 0.8;
    }
    .opacity-90 {
        opacity: 0.9;
    }
    .opacity-10 {
        opacity: 0.1;
    }
    .hover-card {
        transition: transform 0.3s, box-shadow 0.3s;
        cursor: pointer;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
    .btn-outline-primary, .btn-outline-success, .btn-outline-info, .btn-outline-warning, .btn-outline-danger {
        transition: all 0.3s;
    }
    .btn-outline-primary:hover, .btn-outline-success:hover, .btn-outline-info:hover, .btn-outline-warning:hover, .btn-outline-danger:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 10px rgba(0,0,0,0.1);
    }
</style>
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Beykent Spor Kulübü</title>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- ÜST MENÜ (NAVBAR) -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-trophy-fill me-2" style="font-size: 1.8rem; color: gold;"></i>
                    <span class="fw-bold">BEYKENT SPOR</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill me-1"></i>Ana Sayfa
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Uyeler" asp-action="Index">
                                <i class="bi bi-people-fill me-1"></i>Sporcular
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Uyeler" asp-action="Ekle">
                                <i class="bi bi-person-plus-fill me-1"></i>Yeni Sporcu
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Uyeler" asp-action="BorcluUyeler">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i>Borçlular
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Excel" asp-action="UyeleriExcelAktar">
                                <i class="bi bi-file-earmark-excel me-1"></i>Excel Rapor
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <span class="nav-link text-white">
                                <i class="bi bi-calendar-check me-1"></i>@DateTime.Now.ToString("dd MMMM yyyy")
                            </span>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- ANA İÇERİK -->
    <div class="container-fluid mt-3 px-4">
        <main role="main" class="pb-3">
            @if (TempData["Basarili"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Basarili"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="border-top footer text-muted bg-light py-4 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <p class="mb-0">
                        <i class="bi bi-c-circle me-1"></i> @DateTime.Now.Year Beykent Spor Kulübü
                    </p>
                    <p class="mb-0 small">
                        <i class="bi bi-geo-alt-fill me-1 text-primary"></i> Beylikdüzü / İstanbul
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-1"><strong>Spor Salonları:</strong></p>
                    <div>
                        <a asp-controller="Uyeler" asp-action="Index" asp-route-salonId="1" class="btn btn-sm btn-outline-primary me-1">Emlak Konut</a>
                        <a asp-controller="Uyeler" asp-action="Index" asp-route-salonId="2" class="btn btn-sm btn-outline-primary me-1">Yakuplu</a>
                        <a asp-controller="Uyeler" asp-action="Index" asp-route-salonId="3" class="btn btn-sm btn-outline-primary">Neşe Sever</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- JavaScript -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>